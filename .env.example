# Variables compartidas Rust + PHP (misma semántica para loadtest / k6).
# Docker Compose en la raíz usa `rust/.env`. Creá el archivo así:
#   cp .env.example rust/.env
# y editá API_TOKEN. Mismas claves que rust/.env.example y php/.env.example.

API_TOKEN=cambia-este-token-en-produccion
BIND_ADDR=0.0.0.0:8080
OUTPUT_DIR=/data/images
MAX_DOWNLOAD_BYTES=26214400
DOWNLOAD_TIMEOUT_SECS=15
MAX_BODY_BYTES=1048576
# RESIZE_WORKERS=4
JPEG_QUALITY=85
MAX_SCALE=10
RUST_LOG=info
