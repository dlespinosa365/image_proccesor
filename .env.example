# Token requerido para autenticar requests via header Authorization: Bearer <API_TOKEN>
API_TOKEN=cambia-este-token-en-produccion

# Dirección y puerto donde escucha el server dentro del contenedor
BIND_ADDR=0.0.0.0:8080

# Directorio donde se persisten las imágenes redimensionadas (montado como volumen)
OUTPUT_DIR=/data/images

# Límite de bytes de la imagen remota descargada (default 25 MiB)
MAX_DOWNLOAD_BYTES=26214400

# Timeout en segundos para la descarga completa
DOWNLOAD_TIMEOUT_SECS=15

# Tamaño máximo del body JSON aceptado (default 1 MiB)
MAX_BODY_BYTES=1048576

# Cantidad de workers de resize concurrentes. Si se deja vacío usa num_cpus
# RESIZE_WORKERS=4

# Calidad JPEG (1-100). Solo aplica si format=jpeg
JPEG_QUALITY=85

# Máximo factor de escala permitido para evitar imágenes gigantes
MAX_SCALE=10

# Nivel de logs (trace, debug, info, warn, error)
RUST_LOG=info
