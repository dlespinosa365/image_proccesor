# Mismas variables que rust/.env.example para pruebas comparables (k6 / loadtest).
# En Docker, el compose de la raíz inyecta estas variables; PHP ignora RESIZE_WORKERS y RUST_LOG.

API_TOKEN=cambia-este-token-en-produccion
BIND_ADDR=0.0.0.0:8080
OUTPUT_DIR=/data/images
MAX_DOWNLOAD_BYTES=26214400
DOWNLOAD_TIMEOUT_SECS=15
MAX_BODY_BYTES=1048576
# RESIZE_WORKERS=4
JPEG_QUALITY=85
MAX_SCALE=10
RUST_LOG=info
